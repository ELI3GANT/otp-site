{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "*.html",
          "*.css",
          "*.js",
          "*.png",
          "*.jpg",
          "*.jpeg",
          "*.gif",
          "*.svg",
          "*.webp",
          "*.ico",
          "*.webmanifest",
          "*.xml",
          "*.txt",
          "assets/**",
          "supabase/migrations/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "^/os/?$", "dest": "/server.js" },
    { "src": "^/os/(.*)$", "dest": "/server.js" },
    { "src": "/(bookings|booking|book|book-otp)/?", "dest": "/bookings.html" },
    { "src": "/api/bookings/(.*)", "dest": "/server.js" },
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/api", "dest": "/server.js" },
    { "src": "/ping", "dest": "/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
